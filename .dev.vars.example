ADMIN_USER=changeme
ADMIN_PASSWORD=changeme
OPENAI_API_KEY=

# Presigned large direct-to-R2 uploads (P3.1). All three required to enable;
# leave blank and the presign endpoint returns 501. Mint from an R2 API token.
# Endpoint = https://<account-id>.r2.cloudflarestorage.com (default jurisdiction).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=
R2_BUCKET_NAME=moments-media
