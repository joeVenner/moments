{
  "name": "moments",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply moments-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply moments-db --remote",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "canvas-confetti": "^1.9.4",
    "hono": "^4.12.27",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.2",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  }
}
